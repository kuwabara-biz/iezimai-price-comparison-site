# Supabase（公開）
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service_role（サーバー専用・RLSバイパス）
SUPABASE_SERVICE_ROLE_KEY=

# 管理画面ログイン許可メール（カンマ区切り可）
ADMIN_ALLOWED_EMAILS=admin@example.com

# Resend（リード通知メール）
RESEND_API_KEY=
LEAD_NOTIFY_EMAIL=admin@example.com
# RESEND_FROM_EMAIL=onboarding@resend.dev  # 独自ドメイン認証後に変更

# Google Places API（業者公式URL取得スクリプト用、ローカル限定）
# GOOGLE_PLACES_API_KEY=
